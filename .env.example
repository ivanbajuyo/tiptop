# ──────────────────────────────────────────────────
# Tip Top Distribution — Environment Variables
# Copy this file to .env.local and fill in your values
# ──────────────────────────────────────────────────

# Supabase Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase Client (for auth, realtime, storage — optional)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR-ANON-KEY]

# Render Backend URL (the Express server on Render)
NEXT_PUBLIC_BACKEND_URL=https://tiptop-api.onrender.com

# Resend Email
RESEND_API_KEY=re_[YOUR-RESEND-API-KEY]
FROM_EMAIL=noreply@tiptopdistribution.com
ADMIN_EMAIL=killerzwagg123@gmail.com
